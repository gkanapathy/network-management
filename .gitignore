# macOS
.DS_Store
._*
.AppleDouble
.LSOverride

# Editor swap / autosave / undo state
*.swp
*.swo
*~
\#*\#
.\#*
.vscode/*
!.vscode/extensions.json
.idea/
*.iml

# Direnv / env files (per-machine; if you start using them, creds end up here)
.env
.env.*
.envrc
.direnv/

# Generic key material — defensive, never commit even by accident
*.key
*.pem
id_rsa
id_ed25519
id_dsa
*.pfx

# Claude Code: local-only per-machine settings
.claude/settings.local.json

# Omada controller backups: large binary files, belong in backup storage not version control
omada-controller/oc200/backups/*.cfg

# Omada macOS controller software bundle: decommissioned hardware-controller-only setup,
# 272 MB of vendor binaries, kept locally for archive but not version-controlled.
omada-controller/macos-software/

# MikroTik binary backups: sensitive (contain admin secrets),
# restorable via netinstall, not useful for code review.
mikrotik-router/snapshots/*.backup

# Anticipated: ISP creds / PSKs / etc., never committed.
mikrotik-router/secrets.rsc
